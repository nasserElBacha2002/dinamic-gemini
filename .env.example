# =============================================================================
# dinamic-gemini — Variables de entorno (v3 API + pipeline)
# Copiar a .env en la raíz del repo (y/o backend/.env para overrides locales).
# No subir .env al repositorio. La API carga repo/.env y backend/.env.
# =============================================================================

# --- Requisitos por escenario (el resto tiene valores por defecto) ---
# • Pipeline LLM — según LLM_PROVIDER (o provider por job):
#     gemini   → GEMINI_API_KEY
#     openai   → OPENAI_API_KEY
#     claude   → ANTHROPIC_API_KEY
#     deepseek → DEEPSEEK_API_KEY
# • SQL Server — si SQLSERVER_ENABLED=true: SQLSERVER_CONNECTION_STRING
#   o las cuatro variables SQLSERVER_SERVER, SQLSERVER_DATABASE, SQLSERVER_UID, SQLSERVER_PWD
#   (y SQLSERVER_DRIVER si no hay driver ODBC detectado).
# • S3 — si ARTIFACT_STORAGE_PROVIDER=s3: ARTIFACT_S3_BUCKET (región/prefijo opcionales).
# • Auth admin — si usas login v3: ADMIN_USERNAME, ADMIN_PASSWORD_HASH, AUTH_TOKEN_SECRET.
# • API_KEY — opcional; vacío = sin X-API-Key (solo desarrollo).

# --- LLM: proveedor por defecto (per-job puede sobrescribir) ---
# gemini | openai | claude | deepseek  —  Env: LLM_PROVIDER
LLM_PROVIDER=gemini

# --- Gemini (cuando LLM_PROVIDER=gemini o el job usa Gemini) ---
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.0-flash-exp
# GEMINI_MAX_RETRIES=3
# GEMINI_RETRY_DELAY=1.0
# Lista separada por comas para el selector en POST /process
# PROCESSING_GEMINI_MODELS=gemini-2.0-flash-exp,gemini-1.5-flash,gemini-1.5-pro

# --- OpenAI (cuando LLM_PROVIDER=openai o el job usa OpenAI) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# OPENAI_REQUEST_TIMEOUT_SEC=120
# OPENAI_VISION_MAX_IMAGE_SIDE=2048
# PROCESSING_OPENAI_MODELS=gpt-4o,gpt-4o-mini,gpt-4-turbo

# --- Anthropic Claude (cuando LLM_PROVIDER=claude o el job usa Claude) ---
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_REQUEST_TIMEOUT_SEC=120
# ANTHROPIC_VISION_MAX_IMAGE_SIDE=2048
# ANTHROPIC_MAX_OUTPUT_TOKENS=16384
# Retries: overload (529) / rate limit (429) only — not TIMEOUT, auth, or parse/schema errors
# ANTHROPIC_MAX_RETRIES=4
# ANTHROPIC_RETRY_BASE_DELAY_SEC=1.0
# PROCESSING_CLAUDE_MODELS=claude-sonnet-4-20250514,claude-3-5-sonnet-20241022

# --- DeepSeek OpenAI-compatible (cuando LLM_PROVIDER=deepseek) ---
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_API_BASE_URL=https://api.deepseek.com
# DEEPSEEK_REQUEST_TIMEOUT_SEC=120
# DEEPSEEK_VISION_MAX_IMAGE_SIDE=2048
# PROCESSING_DEEPSEEK_MODELS=deepseek-chat,deepseek-vl2

# --- API (FastAPI / worker embebido) ---
# Vacío = sin autenticación por X-API-Key (solo desarrollo)
API_KEY=
# true (default): worker en el mismo proceso que la API (local/dev)
# false: desactivar worker embebido (producción con worker dedicado)
EMBEDDED_WORKER_ENABLED=true
# Reclamar jobs RUNNING obsoletos tras N segundos (0 = desactivado)
WORKER_STALE_RUNNING_TIMEOUT_SEC=900
# Comando para lanzar worker bajo demanda: JSON array de strings o comando shell.
# dev.sh lo define por defecto si está vacío.
# WORKER_ON_DEMAND_COMMAND=
CORS_ALLOW_ORIGINS=
# Proxy (ALB, etc.): * o lista separada por comas de hosts de confianza
# FORWARDED_TRUSTED_HOSTS=

# --- Artefactos (local | s3) ---
ARTIFACT_STORAGE_PROVIDER=local
# Obligatorio si ARTIFACT_STORAGE_PROVIDER=s3
# ARTIFACT_S3_BUCKET=
# ARTIFACT_S3_REGION=
ARTIFACT_S3_PREFIX=v3
ARTIFACT_S3_SIGNED_URL_TTL_SEC=900
ARTIFACT_STORAGE_LEGACY_LOCAL_READ_ENABLED=true
# Límites de memoria al servir/leer JSON grandes (bytes)
# ARTIFACT_STORE_MAX_IN_MEMORY_GET_BYTES=8388608
# ARTIFACT_STORE_MAX_JSON_LOAD_BYTES=33554432

OUTPUT_DIR=output
MAX_UPLOAD_SIZE_MB=500
# Opcional: versión en /health y logs
# GIT_SHA=

# --- v3 runtime (repos SQL) ---
# true (default): si falla SQL, algunos endpoints pueden usar fallback en memoria (dev).
# false: fallar en duro si no hay SQL configurado.
# V3_ALLOW_IN_MEMORY_FALLBACK=true
# Tope de filas crudas por pasillo antes de consolidar en GET .../positions
# V3_POSITIONS_AISLE_RAW_CAP=2000

# --- Auth administrativa (v3) ---
# Con usuario + hash + secret configurados se habilitan rutas de login/tokens.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD_HASH=pbkdf2_sha256$...
# AUTH_TOKEN_SECRET=change-me-in-real-env
# AUTH_TOKEN_EXPIRES_MINUTES=15
# AUTH_REFRESH_TOKEN_EXPIRES_MINUTES=43200

# --- Pipeline híbrido / trazabilidad de prompts ---
# Perfil de prompt (cuerpo compuesto). job puede sobrescribir.
# HYBRID_PROMPT=global_v21
# Solo metadatos / auditoría; no elige el perfil de plantilla:
# PROMPT_VERSION=
EXTRACT_FPS=1.0
# HYBRID_MAX_FRAMES=   (vacío o 0 = sin límite explícito; rango 1..10000)
# MAX_FRAMES_TO_SEND=
# FRAME_STRIDE=1
# TIME_LIMIT_SEC=
# DEBUG_SAVE_FRAMES=false
# DEBUG_LOG_FULL_ANALYSIS_PROMPT=false

# --- SQL Server ---
# true = DB como fuente de verdad cuando hay conexión válida
SQLSERVER_ENABLED=true
SQLSERVER_SERVER=
SQLSERVER_DATABASE=dinamic-gemini
SQLSERVER_UID=
SQLSERVER_PWD=
# SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server
# En contenedor Docker, si SERVER apunta a localhost, se reescribe; override del host:
# SQLSERVER_DOCKER_HOST=host.docker.internal
# Opción B: cadena ODBC completa
# SQLSERVER_CONNECTION_STRING=DRIVER={ODBC Driver 18 for SQL Server};SERVER=...;DATABASE=...;UID=...;PWD=...;TrustServerCertificate=yes

# Guardas de esquema al arranque (migraciones)
# DB_SCHEMA_GUARD_ENABLED=true
# DB_SCHEMA_GUARD_BLOCK_STARTUP=true
# DB_SCHEMA_SERVICE_NAME=inventory-api
# DB_SCHEMA_REQUIRED_VERSION=
# DB_SCHEMA_MIGRATION_LOCK_TIMEOUT_SEC=60
# DEPLOYMENT_ID=

ENGINE_VERSION=v2.0

# --- Entrada por fotos ---
ENABLE_PHOTOS_INPUT=true
MAX_PHOTOS_PER_JOB=12
PHOTOS_MAX_TOTAL_BYTES=26214400
PHOTO_RESIZE_MAX_SIDE=1280
PHOTO_JPEG_QUALITY=85
PHOTOS_MIN_SIDE=320
# PHOTOS_KEEP_ORIGINALS=false
# PHOTOS_MAX_SINGLE_BYTES=

# --- Evidencia (Stage 2.1.D) ---
# EVIDENCE_K_OVERVIEW=3
# EVIDENCE_MAX_IMAGES_PER_PALLET=25
# EVIDENCE_JPEG_QUALITY=85
