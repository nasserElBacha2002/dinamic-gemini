# =============================================================================
# dinamic-gemini — Variables de entorno (V2.3)
# Copiar a .env y completar valores. No subir .env al repositorio.
# =============================================================================

# --- Obligatorio para pipeline (Gemini) ---
GEMINI_API_KEY=

# --- Proveedor LLM (V2.2.D / V2.3.B) ---
# gemini | openai. Env: LLM_PROVIDER. Tests use the executor harness (no fake provider in production).
LLM_PROVIDER=gemini
#
# OpenAI / GPT (cuando elijas provider openai en POST /process o LLM_PROVIDER=openai)
# Requerido para ejecución explícita con provider openai.
OPENAI_API_KEY=
# Modelo por defecto cuando no envías model_name en el job. Env: OPENAI_MODEL.
OPENAI_MODEL=gpt-4o
# OPENAI_REQUEST_TIMEOUT_SEC=120
# OPENAI_VISION_MAX_IMAGE_SIDE=2048
# Lista separada por comas para el selector de modelos en POST /process (UI/API).
# PROCESSING_OPENAI_MODELS=gpt-4o,gpt-4o-mini,gpt-4-turbo
#
# Gemini — modelo por defecto y lista para el selector de POST /process
# GEMINI_MODEL_NAME=gemini-2.0-flash-exp
# PROCESSING_GEMINI_MODELS=gemini-2.0-flash-exp,gemini-1.5-flash,gemini-1.5-pro
# La API carga este archivo desde la raíz del repo además de backend/.env (cwd puede ser backend/).

# --- API (Stage 7) ---
# Vacío = sin autenticación (solo desarrollo)
API_KEY=
# true (default): run embedded worker in API process (local/dev)
# false: disable embedded worker (production with dedicated worker service)
EMBEDDED_WORKER_ENABLED=true
# Reclaim stale RUNNING jobs older than N seconds (0 disables).
# Useful when a worker crashes after claim and before completion.
WORKER_STALE_RUNNING_TIMEOUT_SEC=900
# CORS for FastAPI server. Comma-separated origins.
# Empty/unset = use:
#   http://localhost:5173
#   http://127.0.0.1:5173
CORS_ALLOW_ORIGINS=
# Trust X-Forwarded-Proto / X-Forwarded-For from reverse proxy (e.g. ALB). * = any client IP inside the VPC image default in Dockerfile.
# FORWARDED_TRUSTED_HOSTS=
# Artifact storage provider (Phase 1 S3 foundation): local | s3
ARTIFACT_STORAGE_PROVIDER=local
# Required when ARTIFACT_STORAGE_PROVIDER=s3
# ARTIFACT_S3_BUCKET=
# Optional (default AWS region chain if empty)
# ARTIFACT_S3_REGION=
# S3 object prefix for v3 artifacts
ARTIFACT_S3_PREFIX=v3
# Signed URL TTL for file-serving endpoints in later phases
ARTIFACT_S3_SIGNED_URL_TTL_SEC=900
# During rollout, allow reading legacy local-path records when provider metadata is missing
ARTIFACT_STORAGE_LEGACY_LOCAL_READ_ENABLED=true
OUTPUT_DIR=output
MAX_UPLOAD_SIZE_MB=500

# --- Auth (v3.2.1 — minimal administrative authentication) ---
# Phase 1 defines auth config variables and scaffolding only.
# Auth behavior (login, token issuance, route protection) is wired in later phases.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD_HASH=pbkdf2_sha256$...
# AUTH_TOKEN_SECRET=change-me-in-real-env
# AUTH_TOKEN_EXPIRES_MINUTES=480

# --- Pipeline hybrid (V2.3) ---
GEMINI_MODEL_NAME=gemini-2.0-flash-exp
# Perfil de prompt por defecto (Prompt A: global_v21). Prompt B (experimentación): global_v21_b
# HYBRID_PROMPT=global_v21
EXTRACT_FPS=1.0
# Límite de frames en modo hybrid. Vacío o 0 = sin límite (cap interno 48 por defecto). 1..10000 = límite explícito. Env: HYBRID_MAX_FRAMES.
# HYBRID_MAX_FRAMES=
# Guardar en run/frames_sent/ las imágenes enviadas a Gemini (debug). Env: DEBUG_SAVE_FRAMES.
# DEBUG_SAVE_FRAMES=false

# --- SQL Server (Stage 8) ---
# true = usar DB como fuente de verdad cuando hay conexión. false = solo filesystem.
SQLSERVER_ENABLED=true
# Opción A: variables separadas (recomendado; credenciales solo en env)
SQLSERVER_SERVER=
SQLSERVER_DATABASE=dinamic-gemini
SQLSERVER_UID=
SQLSERVER_PWD=
# SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server
# Opción B: cadena completa
# SQLSERVER_CONNECTION_STRING=DRIVER={ODBC Driver 18 for SQL Server};SERVER=...;DATABASE=...;UID=...;PWD=...;TrustServerCertificate=yes
ENGINE_VERSION=v2.0

# --- Entrada por fotos (Stage 2.2.A) ---
ENABLE_PHOTOS_INPUT=true
MAX_PHOTOS_PER_JOB=12
PHOTOS_MAX_TOTAL_BYTES=26214400
PHOTO_RESIZE_MAX_SIDE=1280
PHOTO_JPEG_QUALITY=85
PHOTOS_MIN_SIDE=320

# --- Evidencia (Stage 2.1.D) ---
# EVIDENCE_K_OVERVIEW=3
# EVIDENCE_MAX_IMAGES_PER_PALLET=25
# EVIDENCE_JPEG_QUALITY=85
