# =============================================================================
# dinamic-gemini — Variables de entorno
# Copiar a .env y completar valores. No subir .env al repositorio.
# =============================================================================

# --- Obligatorio para pipeline (Gemini) ---
GEMINI_API_KEY=

# --- API (Stage 7) ---
# Vacío = sin autenticación (solo desarrollo)
API_KEY=
OUTPUT_DIR=output
MAX_UPLOAD_SIZE_MB=500

# --- SQL Server (Stage 8). Por defecto se usa DB si hay conexión; poner false para solo filesystem ---
# En macOS instalar antes el driver ODBC: brew install msodbcsql18 (ver README).
# Si no hay driver instalado, la app usa solo filesystem sin errores.
SQLSERVER_ENABLED=true
# Opción A: variables separadas (recomendado; credenciales solo en env)
SQLSERVER_SERVER=
SQLSERVER_DATABASE=dinamic-gemini
SQLSERVER_UID=
SQLSERVER_PWD=
# Opcional: nombre del driver (si no se pone, se usa el primero "SQL Server" instalado)
# SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server
# Opción B: cadena completa (si prefieres una sola variable)
# SQLSERVER_CONNECTION_STRING=DRIVER={ODBC Driver 18 for SQL Server};SERVER=...;DATABASE=...;UID=...;PWD=...;TrustServerCertificate=yes
ENGINE_VERSION=v2.0

# --- Pipeline (opcionales, tienen default) ---
GEMINI_MODEL_NAME=gemini-2.0-flash-exp
EXTRACT_FPS=1.0
# MAX_FRAMES_TO_SEND=   # vacío o 0 = sin límite
# HYBRID_MAX_FRAMES=    # vacío o 0 = sin límite en modo hybrid; 1..10000 para límite
OUTPUT_DIR=output
# DEBUG_SAVE_FRAMES=true   # en hybrid: guarda en run/frames_sent/ las imágenes enviadas a Gemini (frame_000000.jpg, ...)
