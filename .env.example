# =============================================================================
# Dinamic Inventory — Variables de entorno (ejemplo)
# =============================================================================
# Copiar a `.env` en la RAÍZ del repo (y opcionalmente `backend/.env` para overrides).
# No commitear `.env` con secretos. Orden de carga: raíz `.env` → `backend/.env` (override).
#
# Lista canónica de campos: backend/src/env_settings/grouped_settings.py
# Lecturas adicionales: env_settings/parsing.py, sqlserver_resolution.py, api/server.py
# =============================================================================

# -----------------------------------------------------------------------------
# App / API runtime
# -----------------------------------------------------------------------------
# Si está definida, todas las rutas excepto GET /health exigen header X-API-Key.
API_KEY=

# Worker en el mismo proceso que la API (true por defecto). dev.sh fuerza false + worker bajo demanda.
EMBEDDED_WORKER_ENABLED=true

# Reclamar jobs RUNNING colgados tras N segundos (0 = desactivado).
WORKER_STALE_RUNNING_TIMEOUT_SEC=900

# JSON array de strings o comando shell para lanzar worker hijo (dev.sh lo define si está vacío).
# WORKER_ON_DEMAND_COMMAND=

# Opcional: el orquestador puede inyectarlas al lanzar el worker (metadatos en logs / contexto).
# DINAMIC_JOB_ID=
# DINAMIC_EXECUTION_ID=

# Orígenes CORS separados por coma. Vacío = por defecto localhost:5173 y 127.0.0.1:5173 en server.py.
CORS_ALLOW_ORIGINS=

# Detrás de proxy TLS: hosts de confianza para X-Forwarded-Proto (coma), p. ej. "*.mi-dominio.com"
# FORWARDED_TRUSTED_HOSTS=

# Versión opcional expuesta en GET /health y logs de arranque.
# GIT_SHA=

# Puerto del proceso: lo usan ./dev.sh y scripts/run-backend.js (no es campo Pydantic).
# PORT=8000

# -----------------------------------------------------------------------------
# SQL Server (persistencia v3)
# -----------------------------------------------------------------------------
# false = no usar SQL como fuente de verdad (solo desarrollo aislado).
SQLSERVER_ENABLED=true

# Opción A — variables separadas (el driver ODBC se autodetecta si SQLSERVER_DRIVER está vacío).
SQLSERVER_SERVER=
SQLSERVER_DATABASE=dinamic-gemini
SQLSERVER_UID=
SQLSERVER_PWD=
# SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server

# En Docker, si SERVER=localhost se reescribe; override del host al SQL del host:
# SQLSERVER_DOCKER_HOST=host.docker.internal

# Opción B — cadena ODBC completa (tiene prioridad si está definida).
# SQLSERVER_CONNECTION_STRING=DRIVER={ODBC Driver 18 for SQL Server};SERVER=...;DATABASE=...;UID=...;PWD=...;TrustServerCertificate=yes

# -----------------------------------------------------------------------------
# Migraciones y guard de esquema (arranque + GET /ready)
# -----------------------------------------------------------------------------
# DB_SCHEMA_GUARD_ENABLED=true
# DB_SCHEMA_GUARD_BLOCK_STARTUP=true
# DB_SCHEMA_SERVICE_NAME=inventory-api
# Si vacío, se infiere desde archivos de migración en backend/src/database/migrations/versions/
# DB_SCHEMA_REQUIRED_VERSION=
# DB_SCHEMA_MIGRATION_LOCK_TIMEOUT_SEC=60
# DEPLOYMENT_ID=

# -----------------------------------------------------------------------------
# Artefactos (evidencias, assets, JSON de pipeline)
# -----------------------------------------------------------------------------
ARTIFACT_STORAGE_PROVIDER=local
# Obligatorio si ARTIFACT_STORAGE_PROVIDER=s3
# ARTIFACT_S3_BUCKET=
# ARTIFACT_S3_REGION=
ARTIFACT_S3_PREFIX=v3
ARTIFACT_S3_SIGNED_URL_TTL_SEC=900
# Obligatorio si ARTIFACT_STORAGE_PROVIDER=gcs (bucket privado; no commitear credenciales)
# GCS_BUCKET_NAME=
# GCS_PROJECT_ID=
GCS_OBJECT_PREFIX=v3
GCS_SIGNED_URL_TTL_SECONDS=900
# Docker: /app/secrets/gcp-service-account.json (mounted from repo secrets/)
# Local ./dev.sh: secrets/gcp-service-account.json or absolute path (dev.sh remaps /app/secrets/…)
# GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gcp-service-account.json
ARTIFACT_STORAGE_LEGACY_LOCAL_READ_ENABLED=true
# ARTIFACT_STORE_MAX_IN_MEMORY_GET_BYTES=8388608
# ARTIFACT_STORE_MAX_JSON_LOAD_BYTES=33554432

OUTPUT_DIR=output
# Per-request upload limits (aisle assets + capture staging). Selection may exceed
# MAX_FILES_PER_UPLOAD_REQUEST via frontend auto-batching.
# MAX_FILES_PER_UPLOAD_REQUEST=10
# Defaults when unset: file=500MB, request=1024MB (historical; must have request >= file).
# MAX_UPLOAD_FILE_SIZE_MB=500
# MAX_UPLOAD_REQUEST_SIZE_MB=1024
# Legacy alias (used if MAX_UPLOAD_FILE_SIZE_MB unset):
MAX_UPLOAD_SIZE_MB=500
# Align reverse-proxy client_max_body_size with MAX_UPLOAD_REQUEST_SIZE_MB (plus multipart overhead).
# Advisory hints surfaced via GET /api/v3/config/upload-limits (server does not enforce these):
# UPLOAD_BATCH_CONCURRENCY=2
# UPLOAD_RETRY_ATTEMPTS=3   # additional retries after first attempt (3 → up to 4 total requests)
# UPLOAD_RETRY_BASE_DELAY_MS=1000
# Recommended photo workload (not historical defaults): see docs/deployment/UPLOAD-PROXY-LIMITS.md
#   MAX_UPLOAD_FILE_SIZE_MB=50 / MAX_UPLOAD_REQUEST_SIZE_MB=250
# Frontend (optional Vite overrides): VITE_MAX_FILES_PER_UPLOAD_REQUEST, VITE_MAX_UPLOAD_FILE_SIZE_MB,
# VITE_MAX_UPLOAD_REQUEST_SIZE_MB, VITE_UPLOAD_BATCH_CONCURRENCY, VITE_UPLOAD_RETRY_ATTEMPTS,
# VITE_UPLOAD_RETRY_BASE_DELAY_MS

# -----------------------------------------------------------------------------
# v3 API — límites y fallback en memoria (desarrollo / producción)
# -----------------------------------------------------------------------------
# Resolución única de backend (C2): todo el contenedor usa SQL o memoria según el modo;
# no hay fallback SQL→memoria por repositorio tras resolver el modo.
#
# V3_ALLOW_IN_MEMORY_FALLBACK:
#   - Si está definido: solo true/1/yes permiten MEMORY_FALLBACK cuando el probe SQL falla.
#   - Si NO está definido: en runtime "production-like" (APP_ENV / ENVIRONMENT / NODE_ENV:
#     production, prod, staging, uat, …) el fallback queda desactivado (fail-fast).
#     En local/dev (sin esas marcas) el fallback sigue permitido por defecto.
# En producción: definir APP_ENV=production (o equivalente) o fijar esta variable explícitamente.
# V3_ALLOW_IN_MEMORY_FALLBACK=true
# APP_ENV=development
# Emergency only: allow v3 process_aisle to continue with protected-base-only prompt when no active supplier_prompt_configs match (default false = fail fast).
# V3_ALLOW_MISSING_SUPPLIER_PROMPT_FALLBACK=false
# V3_POSITIONS_AISLE_RAW_CAP=2000

# -----------------------------------------------------------------------------
# Autenticación administrativa (login /auth/* + sesión Bearer en el frontend)
# -----------------------------------------------------------------------------
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD_HASH=pbkdf2_sha256$...
#
# --- Temporal: segundo operador por env (NO es multi-usuario de producto) ---
# - Sin registro / signup, sin UI de gestión de usuarios, sin RBAC ni permisos por recurso.
# - Mismo rol "administrator" en JWT que el admin primario para rutas v3 estándar.
# - Algunas rutas (p. ej. inspección GET /api/v3/admin/ai-config) quedan reservadas al principal
#   primario (AuthUser.id "admin"), no a Jairo.
# - El login de Jairo es case-sensitive y el nombre fijo es exactamente: Jairo
# - Contraseña solo vía hash en env (mismo formato que ADMIN_PASSWORD_HASH); vacío = desactivado.
# - Requiere siempre ADMIN_USERNAME + ADMIN_PASSWORD_HASH configurados; Jairo es un agregado opcional.
# AUTH_JAIRO_PASSWORD_HASH=pbkdf2_sha256$...
# AUTH_TOKEN_SECRET=change-me-in-real-env
# AUTH_TOKEN_EXPIRES_MINUTES=15
# AUTH_REFRESH_TOKEN_EXPIRES_MINUTES=43200

# -----------------------------------------------------------------------------
# LLM — proveedor por defecto y claves (según el job puede variar)
# -----------------------------------------------------------------------------
# gemini | openai | claude (deepseek is legacy — remapped to gemini for new runs)
LLM_PROVIDER=gemini

GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.0-flash-exp
# GEMINI_MAX_RETRIES=3
# GEMINI_RETRY_DELAY=1.0

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# OPENAI_REQUEST_TIMEOUT_SEC=120
# OPENAI_VISION_MAX_IMAGE_SIDE=2048

# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_REQUEST_TIMEOUT_SEC=120
# Prefer CLAUDE_MULTI_IMAGE_MAX_DIMENSION (default 1800) for multi-image Claude requests.
# CLAUDE_MULTI_IMAGE_MAX_DIMENSION=1800
# CLAUDE_IMAGE_JPEG_QUALITY=88
# OPENAI_IMAGE_JPEG_QUALITY=88
# Legacy ANTHROPIC_VISION_MAX_IMAGE_SIDE is clamped to 1800 when CLAUDE_* is unset
# (Claude many-image hard limit is 2000px — do not rely on 2048).
# ANTHROPIC_VISION_MAX_IMAGE_SIDE=1800
# ANTHROPIC_MAX_OUTPUT_TOKENS=16384
# ANTHROPIC_MAX_RETRIES=4
# ANTHROPIC_RETRY_BASE_DELAY_SEC=1.0

# Deprecated: DeepSeek is no longer available for new executions (historical logs/jobs only).
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_API_BASE_URL=https://api.deepseek.com
# DEEPSEEK_REQUEST_TIMEOUT_SEC=120
# DEEPSEEK_VISION_MAX_IMAGE_SIDE=2048

# Catálogo opcional de pricing LLM (JSON / versión) para costos en compare runs.
# LLM_PRICING_CATALOG_JSON=
# LLM_PRICING_CATALOG_VERSION=

# -----------------------------------------------------------------------------
# Listas de modelos para POST /process y processing-provider-options (coma)
# -----------------------------------------------------------------------------
# PROCESSING_GEMINI_MODELS=gemini-2.0-flash-exp,gemini-1.5-flash,gemini-1.5-pro
# PROCESSING_OPENAI_MODELS=gpt-4o,gpt-4o-mini,gpt-4-turbo
# PROCESSING_CLAUDE_MODELS=claude-sonnet-4-20250514,claude-3-5-sonnet-20241022
# PROCESSING_DEEPSEEK_MODELS=deepseek-chat

# -----------------------------------------------------------------------------
# Pipeline híbrido — análisis y prompts
# -----------------------------------------------------------------------------
# single | multi_parallel | multi_sequential | multi_fallback
# PIPELINE_ANALYSIS_EXECUTION_STRATEGY=single
# PIPELINE_ANALYSIS_EXTRA_PROVIDER_KEYS=

# Phase 1 — aisle identification pipeline (config + snapshot). Default false: legacy LLM path only.
# When true, modes CODE_SCAN/INTERNAL_OCR are snapshotted but still execute LEGACY_LLM_TEMPORARY.
# AISLE_IDENTIFICATION_PIPELINE_ENABLED=false
# Phase 2 — per-asset bookkeeping + exclusive AISLE_BATCH lease (no QR/OCR/per-image LLM yet).
# IMAGE_PROCESSING_ORCHESTRATOR_ENABLED=false
# PROCESSING_ATTEMPTS_ENABLED=false
# IMAGE_PROCESSING_BATCH_LEASE_SECONDS=900
# IMAGE_PROCESSING_ABANDONED_TTL_SECONDS=900
# Phase 3 SINGLE_ASSET concurrency for CODE_SCAN per-image processing (ThreadPool workers).
# Does NOT parallelize the Phase 2 AISLE_BATCH legacy path (must be >= 1).
# Production recommendation: keep 1 until SQL concurrency tests pass (values > 1 rely on the
# ManualImageResultUnitOfWork creating its own connection per `with uow`).
# MAX_IMAGE_PROCESSING_CONCURRENCY=1

# Phase 3 — CODE_SCAN (QR/CODE128). Default OFF for gradual rollout / rollback.
# CODE_SCAN_PROCESSING_ENABLED=false
# When true and mode=CODE_SCAN → execution_strategy=CODE_SCAN.
# When false and mode=CODE_SCAN → LEGACY_LLM_TEMPORARY (pipeline on) or LEGACY_LLM.
# CODE_SCAN_MAX_IMAGE_SIDE=2048
# Wall-clock budget checked BETWEEN scan variants (does NOT interrupt a blocked native decode).
# Prefer CODE_SCAN_VARIANTS_BUDGET_SECONDS; CODE_SCAN_TIMEOUT_SECONDS is a deprecated alias.
# CODE_SCAN_VARIANTS_BUDGET_SECONDS=15
# CODE_SCAN_ENABLE_ROTATIONS=true
# CODE_SCAN_MAX_VARIANTS=4
# CODE_SCAN_QUANTITY_MAX=99999999
# Note: decimal quantities, image preprocessing, and technical-retry loops are NOT implemented.
# CODE_SCAN_ALLOW_DECIMAL_QUANTITY / CODE_SCAN_ENABLE_PREPROCESSING / CODE_SCAN_MAX_TECHNICAL_ATTEMPTS
# are intentionally not exposed here; setting them has no effect (coerced to safe defaults).

# Phase 4 — INTERNAL_OCR (local Tesseract). Default OFF: INTERNAL_OCR still uses LEGACY_LLM_TEMPORARY.
# INTERNAL_OCR_PROCESSING_ENABLED=false
# INTERNAL_OCR_ENGINE=tesseract
# INTERNAL_OCR_LANGUAGE=spa+eng
# INTERNAL_OCR_MAX_VARIANTS=3
# INTERNAL_OCR_TIMEOUT_SECONDS=20
# INTERNAL_OCR_MAX_IMAGE_DIMENSION=2048
# MAX_INTERNAL_IMAGE_PROCESSING_CONCURRENCY=1
# INTERNAL_OCR_QUANTITY_MAX=99999999
# Per-client EAN→internal_code (comma-separated client UUIDs). Do not enable globally for all clients.
# INTERNAL_OCR_EAN_FIRST_CLIENT_IDS=
# INTERNAL_OCR_PREFER_EAN_AS_INTERNAL_CODE=false
# Optional confidence gate (0-100). Empty = disabled. Below threshold → PENDING_MANUAL_REVIEW.
# INTERNAL_OCR_MIN_AGGREGATE_CONFIDENCE=
# INTERNAL_OCR_ENABLE_DESKEW=false
# OCR_LABEL_DETECTION_ENABLED=false
# OCR_DIAGNOSTIC_EVIDENCE_ENABLED=false
# OCR_PROFILE_TEST_TOOL_ENABLED=false
# PROCESSING_EVENTS_PERSISTENCE_ENABLED=false

# Phase 5 — selective external fallback per unresolved image. Default OFF.
# EXTERNAL_FALLBACK_PER_IMAGE_ENABLED=false
# EXTERNAL_FALLBACK_PROVIDER=gemini
# EXTERNAL_FALLBACK_MODEL=
# MAX_EXTERNAL_FALLBACK_CONCURRENCY=1
# EXTERNAL_FALLBACK_TIMEOUT_SECONDS=60
# EXTERNAL_FALLBACK_MAX_ATTEMPTS=1
# EXTERNAL_FALLBACK_CIRCUIT_BREAKER_THRESHOLD=5
# EXTERNAL_FALLBACK_CIRCUIT_BREAKER_COOLDOWN_SECONDS=60
# EXTERNAL_FALLBACK_MAX_IMAGE_DIMENSION=2048
# Multi-provider chains are NOT implemented in Phase 5 — keep false.
# MULTI_PROVIDER_FALLBACK_ENABLED=false

# Phase 6 — supplier extraction profiles (structured rules per client+supplier). Default OFF.
# CLIENT_EXTRACTION_PROFILES_ENABLED=false
# PROFILE_AWARE_VALIDATION_ENABLED=false
# REFERENCE_TEMPLATE_ANNOTATIONS_ENABLED=false

# Phase 7 — per-image operational processing UX (defaults OFF / safe rollback)
# PROCESSING_OBSERVABILITY_ENABLED=false
# PROCESSING_ASSET_LOGS_UI_ENABLED=false
# PROCESSING_ASSET_REPROCESS_ENABLED=false
# PROCESSING_MANUAL_ACTIONS_ENABLED=false
# PROCESSING_EVENTS_PERSISTENCE_ENABLED=false

# Label-first inventory default; set to global_v21 for rollback to logistics-first Prompt A.
HYBRID_PROMPT=global_v22
# PROMPT_VERSION=

EXTRACT_FPS=1.0
# HYBRID_MAX_FRAMES=
# MAX_FRAMES_TO_SEND=
# FRAME_STRIDE=1
# TIME_LIMIT_SEC=
# HEURISTIC_RESIZE_MAX_SIDE=0

# -----------------------------------------------------------------------------
# Entrada por fotos (jobs input_type=photos)
# -----------------------------------------------------------------------------
ENABLE_PHOTOS_INPUT=true
MAX_PHOTOS_PER_JOB=12
PHOTOS_MAX_TOTAL_BYTES=26214400
PHOTO_RESIZE_MAX_SIDE=1280
PHOTO_JPEG_QUALITY=85
PHOTOS_MIN_SIDE=320
# PHOTOS_KEEP_ORIGINALS=false
# PHOTOS_MAX_SINGLE_BYTES=

# -----------------------------------------------------------------------------
# Evidencia (pack de crops / límites)
# -----------------------------------------------------------------------------
# EVIDENCE_K_OVERVIEW=3
# EVIDENCE_K_POS_CANDIDATES=5
# EVIDENCE_K_PROD_CANDIDATES=5
# EVIDENCE_MAX_IMAGES_PER_PALLET=25
# EVIDENCE_JPEG_QUALITY=85

# -----------------------------------------------------------------------------
# Consolidación multi-frame (MAD / umbrales)
# -----------------------------------------------------------------------------
# CONSOLIDATION_MAD_THRESHOLD=3.0
# CONSOLIDATION_MIN_EVIDENCE_FRAMES=2
# CONSOLIDATION_MIN_CONFIDENCE=0.45

# -----------------------------------------------------------------------------
# Motor de jobs (metadato persistido)
# -----------------------------------------------------------------------------
ENGINE_VERSION=v2.0

# -----------------------------------------------------------------------------
# Legacy Stage-8 SQL (soft-freeze; solo si tu despliegue aún cruza tablas legacy)
# -----------------------------------------------------------------------------
# LEGACY_STAGE8_SQL_WRITES_DISABLED=false
# LEGACY_STAGE8_SQL_BRIDGE_DISABLED=false

# -----------------------------------------------------------------------------
# Depuración pipeline / CV (opcional — muchas más en grouped_settings.py)
# -----------------------------------------------------------------------------
# DEBUG_SAVE_FRAMES=false
# DEBUG_LOG_FULL_ANALYSIS_PROMPT=false
# Incluye prompt_text completo en execution log (Analysis request prepared), además de hash y longitud.
# false por defecto; puede contener instrucciones editables del proveedor.
# EXECUTION_LOG_INCLUDE_FULL_PROMPT=false
#
# Observability (job artifacts / logs; downloads are API-proxied — no GCS CORS redirect)
# AUTH_ADMIN_CLIENT_ID=
# AUTH_JAIRO_CLIENT_ID=
# OBSERVABILITY_EXECUTION_LOG_RETENTION_DAYS=90
# OBSERVABILITY_INPUT_ARTIFACT_RETENTION_DAYS=90
# OBSERVABILITY_INTERMEDIATE_ARTIFACT_RETENTION_DAYS=30
# OBSERVABILITY_OUTPUT_ARTIFACT_RETENTION_DAYS=180
# OBSERVABILITY_DEBUG_ARTIFACT_RETENTION_DAYS=14
# OBSERVABILITY_SIGNED_URL_TTL_SECONDS=300
# OBSERVABILITY_TEXT_PREVIEW_MAX_BYTES=65536
# OBSERVABILITY_JSON_PREVIEW_MAX_BYTES=131072
# OBSERVABILITY_IMAGE_PREVIEW_MAX_BYTES=2097152
# OBSERVABILITY_LOG_PAGE_SIZE=100
# OBSERVABILITY_LOG_MAX_PAGE_SIZE=500
# OBSERVABILITY_LOG_MAX_SCAN_BYTES=8000000
# Max artifact download size in bytes. 0 = unlimited (set explicitly to opt back in). Default 104857600 (100MB).
# OBSERVABILITY_DOWNLOAD_MAX_BYTES=104857600
# Fail the job (INPUT_SNAPSHOT_PERSIST_FAILED) if the job_source_assets input snapshot cannot be
# persisted. Set to false to only record a warning on the job result and continue the run.
# OBSERVABILITY_INPUT_SNAPSHOT_REQUIRED=true
# Max concurrent downloads for Observability batch/export operations.
# OBSERVABILITY_DOWNLOAD_MAX_CONCURRENT=4
# Optional staging directory for Observability downloads (defaults to system temp dir).
# OBSERVABILITY_DOWNLOAD_TEMP_DIR=
# Max aggregate bytes staged concurrently in the download temp dir. 0 = unlimited.
# OBSERVABILITY_DOWNLOAD_TEMP_MAX_TOTAL_BYTES=0
# DETECTOR_MODE=stub
# USE_SYNTHETIC_DETECTION=

# -----------------------------------------------------------------------------
# Frontend (Vite) — ver también frontend/.env.example
# -----------------------------------------------------------------------------
# Base URL del API sin barra final. Vacío = mismo origen + proxy en npm run dev.
# VITE_API_BASE_URL=
