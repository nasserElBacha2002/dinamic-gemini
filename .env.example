# =============================================================================
# Dinamic Inventory — Variables de entorno (ejemplo)
# =============================================================================
# Copiar a `.env` en la RAÍZ del repo (y opcionalmente `backend/.env` para overrides).
# No commitear `.env` con secretos. Orden de carga: raíz `.env` → `backend/.env` (override).
#
# Lista canónica de campos: backend/src/env_settings/grouped_settings.py
# Lecturas adicionales: env_settings/parsing.py, sqlserver_resolution.py, api/server.py
# =============================================================================

# -----------------------------------------------------------------------------
# App / API runtime
# -----------------------------------------------------------------------------
# Si está definida, todas las rutas excepto GET /health exigen header X-API-Key.
API_KEY=

# Worker en el mismo proceso que la API (true por defecto). dev.sh fuerza false + worker bajo demanda.
EMBEDDED_WORKER_ENABLED=true

# Reclamar jobs RUNNING colgados tras N segundos (0 = desactivado).
WORKER_STALE_RUNNING_TIMEOUT_SEC=900

# JSON array de strings o comando shell para lanzar worker hijo (dev.sh lo define si está vacío).
# WORKER_ON_DEMAND_COMMAND=

# Opcional: el orquestador puede inyectarlas al lanzar el worker (metadatos en logs / contexto).
# DINAMIC_JOB_ID=
# DINAMIC_EXECUTION_ID=

# Orígenes CORS separados por coma. Vacío = por defecto localhost:5173 y 127.0.0.1:5173 en server.py.
CORS_ALLOW_ORIGINS=

# Detrás de proxy TLS: hosts de confianza para X-Forwarded-Proto (coma), p. ej. "*.mi-dominio.com"
# FORWARDED_TRUSTED_HOSTS=

# Versión opcional expuesta en GET /health y logs de arranque.
# GIT_SHA=

# Puerto del proceso: lo usan ./dev.sh y scripts/run-backend.js (no es campo Pydantic).
# PORT=8000

# -----------------------------------------------------------------------------
# SQL Server (persistencia v3)
# -----------------------------------------------------------------------------
# false = no usar SQL como fuente de verdad (solo desarrollo aislado).
SQLSERVER_ENABLED=true

# Opción A — variables separadas (el driver ODBC se autodetecta si SQLSERVER_DRIVER está vacío).
SQLSERVER_SERVER=
SQLSERVER_DATABASE=dinamic-gemini
SQLSERVER_UID=
SQLSERVER_PWD=
# SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server

# En Docker, si SERVER=localhost se reescribe; override del host al SQL del host:
# SQLSERVER_DOCKER_HOST=host.docker.internal

# Opción B — cadena ODBC completa (tiene prioridad si está definida).
# SQLSERVER_CONNECTION_STRING=DRIVER={ODBC Driver 18 for SQL Server};SERVER=...;DATABASE=...;UID=...;PWD=...;TrustServerCertificate=yes

# -----------------------------------------------------------------------------
# Migraciones y guard de esquema (arranque + GET /ready)
# -----------------------------------------------------------------------------
# DB_SCHEMA_GUARD_ENABLED=true
# DB_SCHEMA_GUARD_BLOCK_STARTUP=true
# DB_SCHEMA_SERVICE_NAME=inventory-api
# Si vacío, se infiere desde archivos de migración en backend/src/database/migrations/versions/
# DB_SCHEMA_REQUIRED_VERSION=
# DB_SCHEMA_MIGRATION_LOCK_TIMEOUT_SEC=60
# DEPLOYMENT_ID=

# -----------------------------------------------------------------------------
# Artefactos (evidencias, assets, JSON de pipeline)
# -----------------------------------------------------------------------------
ARTIFACT_STORAGE_PROVIDER=local
# Obligatorio si ARTIFACT_STORAGE_PROVIDER=s3
# ARTIFACT_S3_BUCKET=
# ARTIFACT_S3_REGION=
ARTIFACT_S3_PREFIX=v3
ARTIFACT_S3_SIGNED_URL_TTL_SEC=900
ARTIFACT_STORAGE_LEGACY_LOCAL_READ_ENABLED=true
# ARTIFACT_STORE_MAX_IN_MEMORY_GET_BYTES=8388608
# ARTIFACT_STORE_MAX_JSON_LOAD_BYTES=33554432

OUTPUT_DIR=output
MAX_UPLOAD_SIZE_MB=500

# -----------------------------------------------------------------------------
# v3 API — límites y fallback en memoria (desarrollo / producción)
# -----------------------------------------------------------------------------
# Resolución única de backend (C2): todo el contenedor usa SQL o memoria según el modo;
# no hay fallback SQL→memoria por repositorio tras resolver el modo.
#
# V3_ALLOW_IN_MEMORY_FALLBACK:
#   - Si está definido: solo true/1/yes permiten MEMORY_FALLBACK cuando el probe SQL falla.
#   - Si NO está definido: en runtime "production-like" (APP_ENV / ENVIRONMENT / NODE_ENV:
#     production, prod, staging, uat, …) el fallback queda desactivado (fail-fast).
#     En local/dev (sin esas marcas) el fallback sigue permitido por defecto.
# En producción: definir APP_ENV=production (o equivalente) o fijar esta variable explícitamente.
# V3_ALLOW_IN_MEMORY_FALLBACK=true
# APP_ENV=development
# Emergency only: allow v3 process_aisle to continue with protected-base-only prompt when no active supplier_prompt_configs match (default false = fail fast).
# V3_ALLOW_MISSING_SUPPLIER_PROMPT_FALLBACK=false
# V3_POSITIONS_AISLE_RAW_CAP=2000

# -----------------------------------------------------------------------------
# Autenticación administrativa (login /auth/* + sesión Bearer en el frontend)
# -----------------------------------------------------------------------------
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD_HASH=pbkdf2_sha256$...
#
# --- Temporal: segundo operador por env (NO es multi-usuario de producto) ---
# - Sin registro / signup, sin UI de gestión de usuarios, sin RBAC ni permisos por recurso.
# - Mismo rol "administrator" en JWT que el admin primario para rutas v3 estándar.
# - Algunas rutas (p. ej. inspección GET /api/v3/admin/ai-config) quedan reservadas al principal
#   primario (AuthUser.id "admin"), no a Jairo.
# - El login de Jairo es case-sensitive y el nombre fijo es exactamente: Jairo
# - Contraseña solo vía hash en env (mismo formato que ADMIN_PASSWORD_HASH); vacío = desactivado.
# - Requiere siempre ADMIN_USERNAME + ADMIN_PASSWORD_HASH configurados; Jairo es un agregado opcional.
# AUTH_JAIRO_PASSWORD_HASH=pbkdf2_sha256$...
# AUTH_TOKEN_SECRET=change-me-in-real-env
# AUTH_TOKEN_EXPIRES_MINUTES=15
# AUTH_REFRESH_TOKEN_EXPIRES_MINUTES=43200

# -----------------------------------------------------------------------------
# LLM — proveedor por defecto y claves (según el job puede variar)
# -----------------------------------------------------------------------------
# gemini | openai | claude | deepseek
LLM_PROVIDER=gemini

GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.0-flash-exp
# GEMINI_MAX_RETRIES=3
# GEMINI_RETRY_DELAY=1.0

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# OPENAI_REQUEST_TIMEOUT_SEC=120
# OPENAI_VISION_MAX_IMAGE_SIDE=2048

# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_REQUEST_TIMEOUT_SEC=120
# ANTHROPIC_VISION_MAX_IMAGE_SIDE=2048
# ANTHROPIC_MAX_OUTPUT_TOKENS=16384
# ANTHROPIC_MAX_RETRIES=4
# ANTHROPIC_RETRY_BASE_DELAY_SEC=1.0

# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_API_BASE_URL=https://api.deepseek.com
# DEEPSEEK_REQUEST_TIMEOUT_SEC=120
# DEEPSEEK_VISION_MAX_IMAGE_SIDE=2048

# Catálogo opcional de pricing LLM (JSON / versión) para costos en compare runs.
# LLM_PRICING_CATALOG_JSON=
# LLM_PRICING_CATALOG_VERSION=

# -----------------------------------------------------------------------------
# Listas de modelos para POST /process y processing-provider-options (coma)
# -----------------------------------------------------------------------------
# PROCESSING_GEMINI_MODELS=gemini-2.0-flash-exp,gemini-1.5-flash,gemini-1.5-pro
# PROCESSING_OPENAI_MODELS=gpt-4o,gpt-4o-mini,gpt-4-turbo
# PROCESSING_CLAUDE_MODELS=claude-sonnet-4-20250514,claude-3-5-sonnet-20241022
# PROCESSING_DEEPSEEK_MODELS=deepseek-chat

# -----------------------------------------------------------------------------
# Pipeline híbrido — análisis y prompts
# -----------------------------------------------------------------------------
# single | multi_parallel | multi_sequential | multi_fallback
# PIPELINE_ANALYSIS_EXECUTION_STRATEGY=single
# PIPELINE_ANALYSIS_EXTRA_PROVIDER_KEYS=

HYBRID_PROMPT=global_v21
# PROMPT_VERSION=

EXTRACT_FPS=1.0
# HYBRID_MAX_FRAMES=
# MAX_FRAMES_TO_SEND=
# FRAME_STRIDE=1
# TIME_LIMIT_SEC=
# HEURISTIC_RESIZE_MAX_SIDE=0

# -----------------------------------------------------------------------------
# Entrada por fotos (jobs input_type=photos)
# -----------------------------------------------------------------------------
ENABLE_PHOTOS_INPUT=true
MAX_PHOTOS_PER_JOB=12
PHOTOS_MAX_TOTAL_BYTES=26214400
PHOTO_RESIZE_MAX_SIDE=1280
PHOTO_JPEG_QUALITY=85
PHOTOS_MIN_SIDE=320
# PHOTOS_KEEP_ORIGINALS=false
# PHOTOS_MAX_SINGLE_BYTES=

# -----------------------------------------------------------------------------
# Evidencia (pack de crops / límites)
# -----------------------------------------------------------------------------
# EVIDENCE_K_OVERVIEW=3
# EVIDENCE_K_POS_CANDIDATES=5
# EVIDENCE_K_PROD_CANDIDATES=5
# EVIDENCE_MAX_IMAGES_PER_PALLET=25
# EVIDENCE_JPEG_QUALITY=85

# -----------------------------------------------------------------------------
# Consolidación multi-frame (MAD / umbrales)
# -----------------------------------------------------------------------------
# CONSOLIDATION_MAD_THRESHOLD=3.0
# CONSOLIDATION_MIN_EVIDENCE_FRAMES=2
# CONSOLIDATION_MIN_CONFIDENCE=0.45

# -----------------------------------------------------------------------------
# Motor de jobs (metadato persistido)
# -----------------------------------------------------------------------------
ENGINE_VERSION=v2.0

# -----------------------------------------------------------------------------
# Legacy Stage-8 SQL (soft-freeze; solo si tu despliegue aún cruza tablas legacy)
# -----------------------------------------------------------------------------
# LEGACY_STAGE8_SQL_WRITES_DISABLED=false
# LEGACY_STAGE8_SQL_BRIDGE_DISABLED=false

# -----------------------------------------------------------------------------
# Depuración pipeline / CV (opcional — muchas más en grouped_settings.py)
# -----------------------------------------------------------------------------
# DEBUG_SAVE_FRAMES=false
# DEBUG_LOG_FULL_ANALYSIS_PROMPT=false
# Incluye prompt_text completo en execution log (Analysis request prepared), además de hash y longitud.
# false por defecto; puede contener instrucciones editables del proveedor.
# EXECUTION_LOG_INCLUDE_FULL_PROMPT=false
# DETECTOR_MODE=stub
# USE_SYNTHETIC_DETECTION=

# -----------------------------------------------------------------------------
# Frontend (Vite) — ver también frontend/.env.example
# -----------------------------------------------------------------------------
# Base URL del API sin barra final. Vacío = mismo origen + proxy en npm run dev.
# VITE_API_BASE_URL=
