# Copy to `.env.test` at repo root and/or `backend/.env.test`.
# Loaded automatically by pytest (see `backend/tests/conftest.py`) with override=True so
# integration tests use a dedicated database instead of your manual dev database.
#
# Database name must look like a test database (e.g. contain `test` / `pytest` / `_test`) or be
# listed in DINAMIC_PYTEST_SQLSERVER_DATABASE_ALLOWLIST — see `src/env_settings/sqlserver_pytest_policy.py`.

# SQLSERVER_CONNECTION_STRING=DRIVER={ODBC Driver 18 for SQL Server};SERVER=127.0.0.1,1433;DATABASE=dinamic_inventory_test;UID=...;PWD=...;TrustServerCertificate=yes

# Or split variables (same as production resolution order; connection string wins if both are set):
# SQLSERVER_SERVER=127.0.0.1,1433
# SQLSERVER_DATABASE=dinamic_inventory_test
# SQLSERVER_UID=sa
# SQLSERVER_PWD=...
# SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server
