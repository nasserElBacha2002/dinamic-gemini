# Base URL for the v3 API (no trailing slash).
# Leave empty to use Vite dev server proxy (same origin).
VITE_API_BASE_URL=

# Optional frontend mirrors for extraction-profile feature flags (used when backend config endpoint is unavailable).
# VITE_REFERENCE_TEMPLATE_ANNOTATIONS_ENABLED=false
# VITE_PROFILE_AWARE_VALIDATION_ENABLED=false
# VITE_CLIENT_EXTRACTION_PROFILES_ENABLED=false
