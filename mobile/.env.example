# Dinamic Inventory mobile client — environment example
# Copy to .env for local development builds. Never commit real values.

# Base URL of the EXISTING backend (same API used by the web frontend).
# These values are read at build time via app.config.ts `extra` and exposed to the
# app through expo-constants. After changing this file, restart Metro with a clean
# cache (`npx expo start --dev-client --clear`) so the new `extra` is picked up.
# Examples:
#   DINAMIC_API_BASE_URL=http://10.0.2.2:8000       # Android EMULATOR -> host localhost
#   DINAMIC_API_BASE_URL=http://192.168.1.50:8000   # PHYSICAL device -> host LAN IP (NOT 127.0.0.1)
#   DINAMIC_API_BASE_URL=https://api.dinamic.example
# NOTE: On a physical phone, 127.0.0.1 / localhost points to the phone itself, not your Mac.
DINAMIC_API_BASE_URL=

# Optional: API key ONLY if the backend has API_KEY set (X-API-Key header).
# Leave empty when the deployment does not enforce a global API key.
DINAMIC_API_KEY=

# development | staging | production
DINAMIC_ENVIRONMENT=development

# Versioning (optional; defaults in app.config.ts)
# DINAMIC_VERSION_NAME=0.3.0
# DINAMIC_VERSION_CODE=30

# Feature flags (1/0). Defaults are permissive for piloto.
# DINAMIC_FLAG_MOBILE_DATA=1
# DINAMIC_FLAG_HEIC_JPEG=1
# DINAMIC_FLAG_WORK_MANAGER=1
# DINAMIC_FLAG_RECONCILE=1
# DINAMIC_FLAG_BG_POLL=1
# DINAMIC_FLAG_AISLE_LOCK=0
# DINAMIC_FLAG_UPLOAD_OBS=1
# Phase 1 upload optimizations: default ON in development/staging, OFF in production (opt-in).
# Set =1 to enable in production; set =0 to force off in non-prod.
# DINAMIC_FLAG_UPLOAD_DIM_CAP=1
# DINAMIC_FLAG_UPLOAD_ADAPTIVE_QUALITY=1
# DINAMIC_FLAG_UPLOAD_ADAPTIVE_CONCURRENCY=1
# Phase 2 background upload: default ON in development/staging, OFF in production (opt-in).
# DINAMIC_FLAG_BG_UPLOAD_WORKER=1
# DINAMIC_FLAG_BG_UPLOAD_FGS=1
# DINAMIC_FLAG_BG_UPLOAD_REBOOT=1
# Phase 3 local CODE_SCAN shadow (default OFF everywhere; hard opt-in).
# DINAMIC_FLAG_LOCAL_CODE_SCAN=1
# DINAMIC_FLAG_LOCAL_CODE_SCAN_COMPARE=1
# DINAMIC_FLAG_LOCAL_CODE_SCAN_DEBUG=1
