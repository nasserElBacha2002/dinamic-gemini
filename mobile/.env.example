# Dinamic Inventory mobile client — environment example
# Copy to .env for local development builds. Never commit real values.

# Base URL of the EXISTING backend (same API used by the web frontend).
# These values are read at build time via app.config.ts `extra` and exposed to the
# app through expo-constants. After changing this file, restart Metro with a clean
# cache (`npx expo start --dev-client --clear`) so the new `extra` is picked up.
# Examples:
#   DINAMIC_API_BASE_URL=http://10.0.2.2:8000       # Android EMULATOR -> host localhost
#   DINAMIC_API_BASE_URL=http://192.168.1.50:8000   # PHYSICAL device -> host LAN IP (NOT 127.0.0.1)
#   DINAMIC_API_BASE_URL=https://api.dinamic.example
# NOTE: On a physical phone, 127.0.0.1 / localhost points to the phone itself, not your Mac.
DINAMIC_API_BASE_URL=

# Optional: API key ONLY if the backend has API_KEY set (X-API-Key header).
# Leave empty when the deployment does not enforce a global API key.
DINAMIC_API_KEY=

# development | staging | production
DINAMIC_ENVIRONMENT=development
